#!/bin/sh
# Install Homebrew packages (runs once on first apply)

set -e

# Ensure brew is in PATH for the rest of this script (required on Apple Silicon)
eval "$(/opt/homebrew/bin/brew shellenv)"

echo "Updating Homebrew..."
brew update

# Install formulae (CLI tools)
echo "Installing Homebrew formulae..."
{{ range .homebrew.brews -}}
brew install {{ . }} || true
{{ end }}

# Install casks (GUI apps)
echo "Installing Homebrew casks..."
{{ range .homebrew.casks -}}
brew install --cask {{ . }} || true
{{ end }}

# Install NVM (Node Version Manager) via official install script
if [ ! -d "$HOME/.nvm" ]; then
  echo "Installing NVM..."
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/HEAD/install.sh | bash
fi

echo "Done installing packages."
